# Copy this file to .env and fill in the values
# cp env.example .env

# ── Database (Neon / Supabase / local PostgreSQL) ──
DATABASE_URL="postgresql://user:password@localhost:5432/invoice_fetcher"

# ── Auth.js ──
# Generate secret: npx auth secret
AUTH_SECRET=""
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"
# Production only: set to your canonical domain (Vercel auto-detects if unset)
# AUTH_URL="https://your-app.vercel.app"

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Python worker (external service) ──
# Default: http://localhost:8000 for local dev
# Production: set to wherever your worker is hosted
WORKER_URL="http://localhost:8000"
