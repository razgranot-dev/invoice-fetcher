# ════════════════════════════════════════════
# מערכת חשבוניות חכמה — הגדרות סביבה
# ════════════════════════════════════════════

# ── Google OAuth2 (חובה) ──────────────────────────────────────────────────
# קבל מ: console.cloud.google.com → APIs & Services → Credentials
# צור OAuth 2.0 Client ID מסוג "Desktop app"
GID=your_client_id_here.apps.googleusercontent.com
GSECRET=your_client_secret_here

# ── הגדרות סריקה (אופציונלי) ─────────────────────────────────────────────
DAYS_BACK=30
UNREAD_ONLY=true
OUTPUT_DIR=output
